# LOCAL DEVELOPMENT ONLY — not used by the deploy pipeline.
# The deployed app uses the production `Dockerfile` (next start); schema is synced by a
# one-shot dev container during deploy (see .github/workflows/azure-deploy.yml).
# This file is here so you can run the app in dev mode locally (`next dev`, push active).
FROM node:20-alpine
WORKDIR /app

# Keep dev mode explicit; npm ci installs devDependencies (needed by `next dev`).
ENV NODE_ENV=development
ENV NEXT_TELEMETRY_DISABLED=1

COPY package.json package-lock.json ./
RUN npm ci

COPY . .

EXPOSE 3001
ENV PORT=3001
ENV HOSTNAME="0.0.0.0"
CMD ["npm", "run", "dev"]
